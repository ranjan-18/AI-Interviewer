# Environment files (backend secrets - never commit!)
backend/.env
.env*.local
.env.production
# Note: frontend/.env is allowed as it only contains the public Render URL

# Node modules (never commit these!)
node_modules/
*/node_modules/
**/node_modules/

# Build output
dist/
build/

# Temporary files
backend/tmp/
*.log
npm-debug.log*

# Vercel
.vercel

# OS files
.DS_Store
Thumbs.db